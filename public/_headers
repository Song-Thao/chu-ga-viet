# Netlify cache & security headers

# Immutable static assets (hashed filenames)
/_next/static/*
  Cache-Control: public, max-age=31536000, immutable
  X-Content-Type-Options: nosniff

# Next.js image optimisation endpoint
/_next/image*
  Cache-Control: public, max-age=86400, stale-while-revalidate=604800

# Favicon
/favicon.ico
  Cache-Control: public, max-age=86400

# Google Search Console verification
/googlebf67eb80774911e3.html
  Cache-Control: public, max-age=86400

# SEO files
/sitemap.xml
  Cache-Control: public, max-age=3600, stale-while-revalidate=86400
  Content-Type: application/xml; charset=utf-8

/robots.txt
  Cache-Control: public, max-age=86400
  Content-Type: text/plain; charset=utf-8

# OG image
/og-image.png
  Cache-Control: public, max-age=604800, stale-while-revalidate=2592000

# API – no cache for AI/mutations
/api/analyze
  Cache-Control: no-store, no-cache

# API – short CDN cache for read endpoints
/api/videos
  Cache-Control: public, s-maxage=3600, stale-while-revalidate=86400

/api/ga
  Cache-Control: public, s-maxage=60, stale-while-revalidate=300

# All pages – short CDN cache, quick stale-while-revalidate
/*
  Cache-Control: public, s-maxage=60, stale-while-revalidate=600
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=()
